02cdcc48def","usedVariables":[]},{"dataSource":{"kind":"inline","dataSourceId":"09fe8187-ff92-4026-b87d-6c01deac8c67"},"text":"['crypto-table']\n| extend movement = iff(priceChangePercent > 0, \"Up\", \"Down\")\n| summarize count() by movement","id":"7d38a029-a415-4f22-b0a7-cf61d6b6e353","usedVariables":[]},{"dataSource":{"kind":"inline","dataSourceId":"09fe8187-ff92-4026-b87d-6c01deac8c67"},"text":"['crypto-table']\n| extend volatility = high - low\n| summarize avg_volatility = avg(volatility) by symbol","id":"ba276c34-1546-4aa7-92ee-872e48817b23","usedVariables":[]},{"dataSource":{"kind":"inline","dataSourceId":"09fe8187-ff92-4026-b87d-6c01deac8c67"},"text":"['crypto-table']\n| where symbol == \"BTCUSDT\"\n| extend event_time = unixtime_seconds_todatetime(timestamp)\n| sort by event_time asc\n| extend prev_price = prev(price), prev_time = prev(event_time)\n| extend change = price - prev_price\n| extend time_diff_sec = datetime_diff('second', event_time, prev_time)\n| extend price_speed = change / time_diff_sec\n| where isnotnull(price_speed)\n| summarize avg_speed = avg(price_speed) by bin(event_time, 1m)\n| order by event_time asc","id":"ae280890-83f9-4053-958d-f796c407af50","usedVariables":[]},{"dataSource":{"kind":"inline","dataSourceId":"09fe8187-ff92-4026-b87d-6c01deac8c67"},"text":"['crypto-table']\n| where symbol in (\"BTCUSDT\", \"ETHUSDT\")\n| summarize arg_max(timestamp, price, priceChangePercent, volume) by symbol\n| project symbol, price, priceChangePercent, volume","id":"b2d37d16-169d-4daa-9093-2c61be112186","usedVariables":[]}],"embeddedApps":[]}